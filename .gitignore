_site/
.quarto/
*.quarto_ipynb
__pycache__/
*.pyc
.DS_Store
.env
*.egg-info/
GitHub_token.rtf
*.h5

# Local design/UX scratch (demos, mockups) — kept on disk for discussion, never
# published or committed (e.g. _scratch/peer-colour-options/ bundles a 3.6 MB
# plotly.min.js). Quarto already ignores it (no render path / not in resources).
_scratch/

/.quarto/

# Internal-only / non-redistributable reference (e.g. CREA MLS HPI — licensed data
# that must NOT be published or committed to this public repo). Local use only.
internal/
*MLS_HPI*

# Brand archive: the extracted folder in visual_assets/initial_drafts/ is committed
# for design history; this zip is a byte-for-byte duplicate of it (1.5 MB).
visual_assets/initial_drafts/*.zip

# Pipeline-generated CPI/social cards at the repo root (derived artifacts). Anchored
# with a leading slash so it does NOT also swallow the tracked brand kit in
# visual_assets/brand/social/ (a bare `social/` matched that dir at any depth).
/social/

# Copernicus CDS credentials — never commit
CDS_key.rtf
CDS_key*
.cdsapirc
*.cdsapirc

# ERA5 climate-map dev previews (not shipped)
data/geo/_preview_*.png
